{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "CommandExecTerminalSize": {
      "description": "PTY size in character cells for `command/exec` PTY sessions.",
      "properties": {
        "cols": {
          "description": "Terminal width in character cells.",
          "format": "uint16",
          "minimum": 0.0,
          "type": "integer"
        },
        "rows": {
          "description": "Terminal height in character cells.",
          "format": "uint16",
          "minimum": 0.0,
          "type": "integer"
        }
      },
      "required": [
        "cols",
        "rows"
      ],
      "type": "object"
    }
  },
  "properties": {
    "processId": {
      "type": "string"
    },
    "size": {
      "$ref": "#/definitions/CommandExecTerminalSize"
    },
    "threadId": {
      "type": "string"
    }
  },
  "required": [
    "processId",
    "size",
    "threadId"
  ],
  "title": "ThreadBackgroundTerminalResizeParams",
  "type": "object"
}