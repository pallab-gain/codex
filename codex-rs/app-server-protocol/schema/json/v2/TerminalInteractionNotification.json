{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "TerminalInputRecord": {
      "oneOf": [
        {
          "properties": {
            "text": {
              "type": "string"
            },
            "type": {
              "enum": [
                "plaintext"
              ],
              "title": "PlaintextTerminalInputRecordType",
              "type": "string"
            }
          },
          "required": [
            "text",
            "type"
          ],
          "title": "PlaintextTerminalInputRecord",
          "type": "object"
        },
        {
          "properties": {
            "kind": {
              "$ref": "#/definitions/TerminalInputRedactionKind"
            },
            "len": {
              "format": "uint",
              "minimum": 0.0,
              "type": "integer"
            },
            "type": {
              "enum": [
                "redacted"
              ],
              "title": "RedactedTerminalInputRecordType",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "len",
            "type"
          ],
          "title": "RedactedTerminalInputRecord",
          "type": "object"
        },
        {
          "properties": {
            "type": {
              "enum": [
                "empty_poll"
              ],
              "title": "EmptyPollTerminalInputRecordType",
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "title": "EmptyPollTerminalInputRecord",
          "type": "object"
        }
      ]
    },
    "TerminalInputRedactionKind": {
      "enum": [
        "password",
        "passphrase",
        "pin",
        "unknown"
      ],
      "type": "string"
    }
  },
  "properties": {
    "input": {
      "$ref": "#/definitions/TerminalInputRecord"
    },
    "itemId": {
      "type": "string"
    },
    "processId": {
      "type": "string"
    },
    "threadId": {
      "type": "string"
    },
    "turnId": {
      "type": "string"
    }
  },
  "required": [
    "input",
    "itemId",
    "processId",
    "threadId",
    "turnId"
  ],
  "title": "TerminalInteractionNotification",
  "type": "object"
}